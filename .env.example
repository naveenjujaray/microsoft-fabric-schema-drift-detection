# Anthropic
ANTHROPIC_API_KEY=

# Azure AD app registration (service principal) - shared by Fabric + Graph (Teams/Outlook)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Auth method override (default: auto-detect)
#   client_secret | managed_identity | notebookutils | default
# Inside a Fabric notebook this auto-resolves to notebookutils (no secrets needed);
# on Azure compute set managed_identity (AZURE_CLIENT_ID optional, for user-assigned MI)
FABRIC_AUTH_METHOD=

# GitHub (PR creation) - used by gh CLI or REST fallback
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Notification channels
SLACK_WEBHOOK=
SLACK_BOT_TOKEN=
TEAMS_WEBHOOK=

# Outlook SMTP fallback (only if notifications.outlook.mode = smtp)
SMTP_USERNAME=
SMTP_PASSWORD=
