# Anthropic
ANTHROPIC_API_KEY=

# Azure AD app registration (service principal) - shared by Fabric + Graph (Teams/Outlook)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Auth method override (default: auto-detect)
#   client_secret | managed_identity | notebookutils | default
# Inside a Fabric notebook this auto-resolves to notebookutils (no secrets needed);
# on Azure compute set managed_identity (AZURE_CLIENT_ID optional, for user-assigned MI)
FABRIC_AUTH_METHOD=

# GitHub (PR creation) - used by gh CLI or REST fallback
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Notification channels
SLACK_WEBHOOK=
SLACK_BOT_TOKEN=
TEAMS_WEBHOOK=

# Outlook SMTP fallback (only if notifications.outlook.mode = smtp)
SMTP_USERNAME=
SMTP_PASSWORD=

# Direct-connect source backends (mode: source) - install extras per source
# SAP HANA (pip install .[hana])
HANA_HOST=
HANA_PORT=
HANA_USER=
HANA_PASSWORD=

# Snowflake (pip install .[snowflake])
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# Databricks / Unity Catalog (pip install .[databricks])
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=

# Azure SQL / SQL Server (pip install .[sqlserver])
SQLSERVER_HOST=
SQLSERVER_DATABASE=
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_PORT=
SQLSERVER_DRIVER=
SQLSERVER_TRUST_CERT=

# PostgreSQL - RDS/Aurora (pip install .[postgres])
POSTGRES_HOST=
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=

# AWS Redshift (pip install .[redshift])
REDSHIFT_HOST=
REDSHIFT_DATABASE=
REDSHIFT_USER=
REDSHIFT_PASSWORD=
REDSHIFT_PORT=

# MySQL / Aurora MySQL (pip install .[mysql])
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_PORT=

# Azure Cosmos DB (pip install .[cosmos])
COSMOS_ENDPOINT=
COSMOS_KEY=
